{
  "name": "@m5/ui",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@m5/types": "workspace:*",
    "react": "18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.23"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format cjs --dts",
    "dev": "tsup src/index.tsx --format cjs --dts --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test $(find src -type f -name '*.test.ts' -o -name '*.test.tsx' | sort)"
  }
}
