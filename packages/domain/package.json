{
  "name": "@m5/domain",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@m5/types": "workspace:*"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test $(find src -type f -name '*.test.ts' | sort)"
  }
}
