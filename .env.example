# ═══════════════════════════════════════════════════════════════
# M5 Monorepo — Environment Variables Template
# 复制本文件为 .env 并填写实际值
# 生产环境通过 CI/CD Pipeline 注入或 K8s Secrets
# ═══════════════════════════════════════════════════════════════

# ─── Node ──────────────────────────────────────────────
NODE_ENV=production

# ─── API ───────────────────────────────────────────────
API_PORT=3001
LYT_MODE=dev
CORS_ORIGIN=http://localhost:3002,http://localhost:3003,http://localhost:3011
LOG_LEVEL=info

# ─── Database ──────────────────────────────────────────
POSTGRES_USER=m5
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=m5
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://m5:change-me-in-production@postgres:5432/m5

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── RabbitMQ ──────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=m5
RABBITMQ_PASSWORD=change-me-in-production

# ─── MinIO ─────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=m5
MINIO_SECRET_KEY=change-me-in-production

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=change-me-in-production-please-generate-a-secure-random-string
JWT_EXPIRES_IN=7d

# ─── Encryption ───────────────────────────────────────
# 通用加密密钥，用于敏感数据字段加密 (32字节 hex)
ENCRYPTION_KEY=
# AI 模型配置专用加密密钥（生产环境必须设置，拒绝退化为开发密钥）
AI_MODEL_ENCRYPTION_KEY=
# 多租户数据隔离加密密钥
TENANT_ENCRYPTION_KEY=

# ─── Internal API Key ────────────────────────────────
# 内部服务间调用的共享 API 密钥
API_KEY=

# ─── Auth / SSO ───────────────────────────────────────
# OIDC SSO 认证
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_ISSUER=
# SAML SSO 认证
SSO_SAML_ENTRY_POINT=
SSO_SAML_CERT=
# SSO JWT 签名密钥（与 JWT_SECRET 独立）
SSO_JWT_SECRET=

# ─── LLM / AI ──────────────────────────────────────────
LLM_DEFAULT_PROVIDER=deepseek
LLM_DEEPSEEK_API_KEY=
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_DEEPSEEK_MODEL=deepseek-chat
LLM_DEEPSEEK_TIMEOUT_MS=60000
LLM_DEEPSEEK_MAX_RETRIES=3
LLM_FALLBACK_CHAIN=deepseek,openai,claude

LLM_OPENAI_API_KEY=
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_OPENAI_MODEL=gpt-4o-mini

LLM_CLAUDE_API_KEY=
LLM_CLAUDE_BASE_URL=https://api.anthropic.com
LLM_CLAUDE_MODEL=claude-sonnet-4-6

LLM_MONTHLY_HARD_LIMIT_USD=100
LLM_MONTHLY_SOFT_LIMIT_USD=80
LLM_ALERT_THRESHOLD=0.8
LLM_ENABLE_PROMPT_CACHE=true
LLM_CACHE_TTL_SECONDS=86400

# ─── Embedding ─────────────────────────────────────────
EMBEDDING_PROVIDER=text-embedding-3-small

# ─── Qdrant ────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# ─── Vault (Hashicorp Vault) ──────────────────────────
VAULT_ADDR=
VAULT_TOKEN=
VAULT_SECRET_PATH=secret/data/ai-model-config
VAULT_AI_MODEL_KEY=

# ─── Finances ─────────────────────────────────────────
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
WECHAT_RECON_SIGNING_SECRET=

# ─── Multimedia ─────────────────────────────────────
MULTIMEDIA_SIGN_SECRET=

# ─── Tracing / Observability ───────────────────────────
ENABLE_TRACING=false
OTLP_EXPORTER=none
OTLP_ENDPOINT=

# ─── Frontend ──────────────────────────────────────────
PORT=3002
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_TELEMETRY_DISABLED=1

# ─── Docker Build ──────────────────────────────────────
BUILD_TAG=latest
REGISTRY=ghcr.io/shenjiying/shenjiying88
