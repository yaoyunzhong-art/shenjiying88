#!/bin/sh
# .githooks/pre-commit · 神机营 SaaS
# 触发条件: git commit 之前
# 功能: 自动跑知识库 lint + commit message 规范检查
#
# 安装: scripts/install-hooks.sh (使用 git config core.hooksPath .githooks)
# 跳过: git commit --no-verify

set -e

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "============================================"
echo "🪝 pre-commit hook · 神机营 SaaS"
echo "============================================"

# ---------- 1. 检查 commit message 格式 (拦截) ----------
COMMIT_MSG_FILE="$1"
if [ -n "$COMMIT_MSG_FILE" ] && [ -f "$COMMIT_MSG_FILE" ]; then
  FIRST_LINE=$(head -n 1 "$COMMIT_MSG_FILE")
  # 检查 Pulse / Phase / 🐜 / 🦞 / 🚀 / 📝 等前缀
  if ! echo "$FIRST_LINE" | grep -qE "^(Pulse-[0-9]+|Phase-[0-9]+|🐜|🦞|🚀|📝|🔧|📚)(:| )" \
    && ! echo "$FIRST_LINE" | grep -qE "^(fix|feat|chore|docs|refactor|test|style|perf)(\([a-zA-Z0-9._/-]+\))?:"; then
    echo "${RED}❌ commit message 第一行格式错误:${NC}"
    echo "   $FIRST_LINE"
    echo ""
    echo "正确格式示例:"
    echo "  Pulse-67: 招募 Approver (P0-004)"
    echo "  Phase-17: 跨门店优惠券服务"
    echo "  🐜 自动: [类型] [模块] 描述"
    echo "  🦞 验收: pulse#67 🟢 0测试失败 TSC0 闭环:#0 新修:#0"
    echo "  feat: 新增功能"
    echo "  fix(loyalty): 收口业务异常"
    echo ""
    echo "如需跳过检查 (不推荐): git commit --no-verify"
    exit 1
  fi
  # 检查长度 (≤72 字符)
  if [ ${#FIRST_LINE} -gt 72 ]; then
    echo "${YELLOW}⚠️  警告: commit message 第一行超过 72 字符 (${#FIRST_LINE})${NC}"
  fi
fi

# ---------- 2. 知识库 lint (如果有 knowledge/ 改动) ----------
STAGED_KNOWLEDGE=$(git diff --cached --name-only --diff-filter=AM | grep "^knowledge/" || true)
if [ -n "$STAGED_KNOWLEDGE" ]; then
  echo ""
  echo "🔍 检测到 knowledge/ 改动,跑 lint-knowledge.py..."
  if [ -f "scripts/lint-knowledge.py" ]; then
    if python3 scripts/lint-knowledge.py; then
      echo "${GREEN}✅ 知识库 lint 通过${NC}"
    else
      echo "${RED}❌ 知识库 lint 失败${NC}"
      echo ""
      echo "修复方法:"
      echo "  python3 scripts/lint-knowledge.py --fix    # 自动修复 frontmatter"
      echo "  python3 scripts/lint-knowledge.py          # 查看详情"
      echo ""
      echo "如需跳过 (不推荐): git commit --no-verify"
      exit 1
    fi
  else
    echo "${YELLOW}⚠️  scripts/lint-knowledge.py 不存在, 跳过${NC}"
  fi
fi

# ---------- 3. TypeScript 类型检查 (可选,默认跳过) ----------
# 默认关闭 - 留给 CI
# 如果想启用,取消下面注释:
# if [ -f "package.json" ] && grep -q "\"typecheck\"" package.json; then
#   echo ""
#   echo "🔍 跑 typecheck..."
#   pnpm typecheck || { echo "❌ typecheck 失败"; exit 1; }
# fi

# ---------- 4. ESLint (可选,默认跳过) ----------
# 默认关闭 - 留给 CI
# if [ -f ".eslintrc.json" ] || [ -f ".eslintrc.js" ]; then
#   echo ""
#   echo "🔍 跑 eslint..."
#   pnpm lint || { echo "❌ lint 失败"; exit 1; }
# fi

echo ""
echo "${GREEN}✅ pre-commit 检查通过${NC}"
echo "============================================"
echo ""
exit 0
