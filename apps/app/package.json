{
  "name": "@m5/app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test $(find . -maxdepth 1 -type f -name '*.test.ts' | sort)"
  },
  "dependencies": {
    "@m5/sdk": "workspace:*",
    "@m5/types": "workspace:*",
    "expo": "~51.0.39",
    "expo-status-bar": "~1.12.1",
    "react": "18.3.1",
    "react-native": "0.74.5"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@types/react": "^18.3.23",
    "typescript": "^5.8.3"
  }
}
