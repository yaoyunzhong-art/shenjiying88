{
  "name": "@m5/app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test $(find . -maxdepth 3 -name '*.test.ts' | sort) 2>/dev/null",
    "test:render": "echo '⚠️  render tests need vitest setup (esbuild+react-native conflict)'; echo 'see: test/README.md'"
  },
  "dependencies": {
    "@m5/sdk": "workspace:*",
    "@m5/types": "workspace:*",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/netinfo": "^11.3.2",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~51.0.39",
    "expo-camera": "14.0.2",
    "expo-device": "^5.2.1",
    "expo-local-authentication": "^13.8.0",
    "expo-localization": "^14.8.1",
    "expo-notifications": "^0.28.19",
    "expo-status-bar": "~1.12.1",
    "i18n": "^0.15.3",
    "react": "18.3.1",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "^4.14.1",
    "react-native-screens": "^3.37.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@types/react": "^18.3.23",
    "typescript": "^5.8.3"
  }
}
