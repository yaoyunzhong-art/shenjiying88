{
  "name": "@m5/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:migrate:status": "prisma migrate status --schema prisma/schema.prisma",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 $(find src -type f \\( -name '*.test.ts' -o -name '*.spec.ts' \\) | sort)"
  },
  "dependencies": {
    "@m5/domain": "workspace:*",
    "@m5/types": "workspace:*",
    "@nestjs/common": "^10.4.17",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.17",
    "@nestjs/platform-express": "^10.4.17",
    "@nestjs/swagger": "^7.4.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.52.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@prisma/client": "^6.10.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "helmet": "^8.2.0",
    "jest": "^30.4.2",
    "nanoid": "^5.1.15",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.17",
    "@opentelemetry/sdk-trace-base": "^1.28.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.10.1",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.8.3"
  }
}
