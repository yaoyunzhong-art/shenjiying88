# ============================================================
# 神机营体育 API 环境变量
# 国内环境配置 — 使用 DeepSeek 为主、Qwen 为备
# ============================================================

# === AI/LLM 配置 ===
# 默认提供商改为 deepseek（国内可用）
LLM_DEFAULT_PROVIDER=deepseek

# DeepSeek（国内主选）
# 获取 API Key: https://platform.deepseek.com/api_keys
LLM_DEEPSEEK_API_KEY=your_deepseek_api_key_here
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_DEEPSEEK_MODEL=deepseek-chat
LLM_DEEPSEEK_TIMEOUT_MS=60000
LLM_DEEPSEEK_MAX_RETRIES=3

# OpenAI（备用，国内需代理）
LLM_OPENAI_API_KEY=
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_OPENAI_MODEL=gpt-4o-mini
LLM_OPENAI_TIMEOUT_MS=30000
LLM_OPENAI_MAX_RETRIES=3

# Claude（备用，国内需代理）
LLM_CLAUDE_API_KEY=
LLM_CLAUDE_BASE_URL=https://api.anthropic.com
LLM_CLAUDE_MODEL=claude-sonnet-4-6
LLM_CLAUDE_TIMEOUT_MS=60000
LLM_CLAUDE_MAX_RETRIES=3

# 降级链：deepseek -> openai -> claude
LLM_FALLBACK_CHAIN=deepseek,openai,claude

# 月度预算控制
LLM_MONTHLY_HARD_LIMIT_USD=100
LLM_MONTHLY_SOFT_LIMIT_USD=80
LLM_ALERT_THRESHOLD=0.8
LLM_ENABLE_PROMPT_CACHE=true
LLM_CACHE_TTL_SECONDS=86400

# === RAG / Embedding 配置 ===
EMBEDDING_PROVIDER=text-embedding-3-small
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
COHERE_API_KEY=
RAG_LLM_PROVIDER=deepseek
RAG_LLM_MODEL=deepseek-chat
RAG_CACHE_ENABLED=true

# === Qdrant 向量数据库 ===
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# === 数据库 ===
DATABASE_URL=postgresql://yaoyunzhong@127.0.0.1:5432/shenjiying
POSTGRES_URL=postgresql://yaoyunzhong@127.0.0.1:5432/shenjiying

# === Redis ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# === 基础配置 ===
JWT_SECRET=dev-jwt-secret-change-in-production
API_PORT=3000
LYT_MODE=dev
