  redirectUris      String[]
  webhookTopics     String[]
  rateLimitPolicyId String?
  sandboxEnabled    Boolean             @default(true)
  status            String              @default("ACTIVE")
  metadata          Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([tenantId, brandId, storeId, status])
}

model RateLimitPolicy {
  id               String              @id @default(cuid())
  code             String              @unique
  scopeType        FoundationScopeType
  tenantId         String?
  brandId          String?
  storeId          String?
  integrationAppId String?
  period           QuotaPeriod
  limit            Int
  burstLimit       Int?
  dimensionKeys    String[]
  algorithm        String              @default("TOKEN_BUCKET")
  metadata         Json?
  quotas           QuotaLedger[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([scopeType, tenantId, brandId, storeId])
}

model QuotaLedger {
  id                String          @id @default(cuid())
  rateLimitPolicyId String
  subjectKey        String
  period            QuotaPeriod
  consumed          Int             @default(0)
  remaining         Int?
  resetAt           DateTime
  metadata          Json?
  rateLimitPolicy   RateLimitPolicy @relation(fields: [rateLimitPolicyId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([rateLimitPolicyId, subjectKey, resetAt])
  @@index([subjectKey, resetAt])
}

model FeatureFlag {
  id              String              @id @default(cuid())
  key             String
  name            String
  scopeType       FoundationScopeType
  tenantId        String?
  brandId         String?
  storeId         String?
  marketProfileId String?
  status          FeatureFlagStatus
  strategy        RolloutStrategy
  enabled         Boolean             @default(false)
  percentage      Int?
  allowList       String[]
  conditions      Json?
  startsAt        DateTime?
  endsAt          DateTime?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([key, status])
  @@index([scopeType, tenantId, brandId, storeId, marketProfileId])
}

model BackupSnapshot {
  id           String              @id @default(cuid())
  resourceType String
  resourceId   String
  scopeType    FoundationScopeType
  tenantId     String?
  brandId      String?
  storeId      String?
  status       BackupStatus
  storageUri   String
  checksum     String?
  metadata     Json?
  capturedAt   DateTime
  expiresAt    DateTime?
  restores     RestoreRun[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([scopeType, tenantId, brandId, storeId, capturedAt])
}

model RestoreRun {
  id                String              @id @default(cuid())
  backupSnapshotId  String
  scopeType         FoundationScopeType
  tenantId          String?
  brandId           String?
  storeId           String?
  status            RestoreStatus
  requestedBy       String
  targetEnvironment String
  validationReport  Json?
  startedAt         DateTime?
  finishedAt        DateTime?
  backupSnapshot    BackupSnapshot      @relation(fields: [backupSnapshotId], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status, createdAt])
}

model PiiPolicy {
  id               String              @id @default(cuid())
  fieldName        String
  piiLevel         PiiLevel
  scopeType        FoundationScopeType
  tenantId         String?
  brandId          String?
  storeId          String?
  marketCode       String?
  maskingStrategy  String
  retentionDays    Int?
  purposeLimit     String[]
  approvalRequired Boolean             @default(false)
  metadata         Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([fieldName, piiLevel])
  @@index([scopeType, tenantId, brandId, storeId, marketCode])
}

model AiModelConfig {
  id              String              @id @default(cuid())
  provider        AiProvider
  model           String
  scopeType       FoundationScopeType
  tenantId        String?
  brandId         String?
  storeId         String?
  maxInputTokens  Int
  maxOutputTokens Int
  costQuotaId     String?
  safetyPolicyId  String?
  enabled         Boolean             @default(true)
  metadata        Json?
  prompts         AiPromptTemplate[]
  executions      AiExecutionRecord[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([provider, model, enabled])
  @@index([scopeType, tenantId, brandId, storeId])
}

model AiPromptTemplate {
  id            String              @id @default(cuid())
  code          String
  modelConfigId String
  version       Int
  prompt        String
  variables     String[]
  outputSchema  Json?
  modelConfig   AiModelConfig       @relation(fields: [modelConfigId], references: [id])
  executions    AiExecutionRecord[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([code, version, modelConfigId])
}

model AiExecutionRecord {
  id               String              @id @default(cuid())
  modelConfigId    String
  promptTemplateId String?
  scopeType        FoundationScopeType
