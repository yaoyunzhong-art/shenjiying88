  @@index([eventId])
}

model FileAsset {
  id              String              @id @default(cuid())
  kind            FileAssetKind
  scopeType       FoundationScopeType
  tenantId        String?
  brandId         String?
  storeId         String?
  marketProfileId String?
  bucket          String
  objectKey       String
  mimeType        String
  size            Int
  checksum        String?
  tags            String[]
  metadata        Json?
  piiLevel        PiiLevel            @default(INTERNAL)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

