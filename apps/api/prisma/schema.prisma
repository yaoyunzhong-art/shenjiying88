// ============ P0-A1 零持久化修复: 三级配置持久化 + 审计 ============
// Phase-FP tenant-config 持久化层 (替代内存 Map, V9 需求 2 180 天审计)
model ConfigInstance {
  id        String   @id @default(cuid())
  key       String
  value     String
  encrypted Boolean  @default(false)
  category  String
  level     String // store | tenant | brand
  ownerId   String
  inherits  Boolean  @default(false)
  version   Int      @default(1)
  updatedBy String
  fromSeed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([level, ownerId, key])
  @@index([level, ownerId])
  @@index([key])
}

model ConfigAuditLog {
  id            String   @id @default(cuid())
  configId      String
  key           String
  level         String
  ownerId       String
  tenantId      String
  action        String // create | update | delete | rollback
  operator      String
  operatorRole  String
  previousValue String?
  newValue      String?
  context       Json?
  timestamp     DateTime @default(now())

  @@index([configId])
  @@index([tenantId, timestamp])
}

// ============ AI V11: 营销推送决策日志 ============
model MarketingPushDecisionLog {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  memberId  String?   @map("member_id")
  pushType  String    @map("push_type") // sms | email | app_notification | wechat
  channel   String? // 推送渠道
  content   String? // 推送内容(摘要)
  decision  String // accept | reject | pending
  reason    String? // 决策原因
  status    String    @default("pending") // pending | sent | failed
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([tenantId, pushType, createdAt])
  @@index([tenantId, memberId, createdAt])
  @@index([tenantId, decision, status])
  @@map("marketing_push_decision_log")
}

// ============ P-30 物流模块: 巡检任务 ============
model InspectionTask {
  id              String    @id @default(cuid())
  tenantId        String
  storeId         String?
  equipmentId     String
  equipmentName   String
  assigneeId      String
  assigneeName    String
  scheduledAt     DateTime
  remindedAt      DateTime?
  result          String?   // normal | warning | fault
  note            String?
  inspectorId     String?
  inspectorName   String?
  status          String    @default("scheduled") // scheduled | reminded | completed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, scheduledAt])
  @@map("inspection_task")
}

// ── ADR-045 科学知识体系V2: 赋能卡片 ──

model EmpowerCard {
  id              String   @id @default(uuid())
  tag             String   // 标签: 竞品|技术|市场|用户|合规|设备|会员|运营|选址
  summary         String   // 摘要 (≤140字)
  source          String   // 来源: ZVZO2026|内部成熟模式|国家标准|...
  freshnessScore  Int      @default(100) // 新鲜度 0-100
  moduleMapping   String?  // 模块映射: P-38/会员系统/RBAC/...
  quoteCount      Int      @default(0)   // 引用次数
  lastQuotedAt    DateTime? // 最后引用时间
  confidence      Int      @default(50)  // 可信度 0-100 (sourceTrust×0.3+vetted×0.4+fresh×0.3)
  expertVetted    Boolean  @default(false) // 是否经专家校审
  detailUrl       String?  // 详细内容链接 (docs/knowledge/xxx)
  quoteLogs       EmpowerCardQuoteLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tag])
  @@index([freshnessScore])
  @@index([quoteCount])
  @@map("empower_card")
}

// ============ B2-5 Invoice Prisma 持久化 ============
model InvoiceV2 {
  id             String    @id @default(cuid())
  tenantId       String
  invoiceNo      String    @unique
  orderId        String?
  type           String    // ELECTRONIC / PAPER / SPECIAL
  amountCents    Int
  taxAmountCents Int       @default(0)
  taxRate        Float     @default(0.13)
  status         String    @default("DRAFT") // DRAFT / ISSUED / CANCELLED / RED_FLUSH / ARCHIVED
  buyerName      String?
  buyerTaxId     String?
  buyerEmail     String?
  remark         String?
  issuedAt       DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId])
  @@index([orderId])
  @@index([status])
  @@map("invoice_v2")
}

model EmpowerCardQuoteLog {
  id          String   @id @default(uuid())
  card        EmpowerCard @relation(fields: [cardId], references: [id])
  cardId      String
  quotedBy    String   // sessionKey/taskName
  quotedAt    DateTime @default(now())
  taskName    String   // 派单任务名
  moduleName  String   // 引用模块

  @@index([cardId])
  @@index([quotedAt])
  @@map("empower_card_quote_log")
}

// ═══════════════════════════════════════════════════════════════
// P-38 财务对账 - Reconciliation models
// ═══════════════════════════════════════════════════════════════

model ReconciliationReportModel {
  id              String          @id @default(uuid())
  tenantId        String?
  date            String          // YYYY-MM-DD
  internalTotal   Int             @default(0)
  externalTotal   Int             @default(0)
  matchedCount    Int             @default(0)
  exactMatchCount Int             @default(0)
  internalTotalCents Int          @default(0)
  externalTotalCents Int          @default(0)
  totalDiffCents  Int             @default(0)
  matchKeyType    String          @default("orderNo")
  durationMs      Int             @default(0)
  toleranceCents  Int             @default(0)
  generatedAt     DateTime        @default(now())
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  diffs           ReconcileDiffModel[]
  matches         ReconcileMatchModel[]

  @@index([tenantId])
  @@index([date])
  @@index([tenantId, date])
  @@map("reconciliation_report")
}

model ReconcileDiffModel {
  id                  String          @id @default(uuid())
  reportId            String
  kind                String          // amount-mismatch | missing-internal | missing-external | duplicate
  orderNo             String?
  internalId          String?
  externalId          String?
  internalAmountCents Int?
  externalAmountCents Int?
  diffCents           Int             @default(0)
  duplicateIds        String?
  note                String?

  report              ReconciliationReportModel @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([kind])
  @@map("reconcile_diff")
}

model ReconcileMatchModel {
  id                  String          @id @default(uuid())
  reportId            String
  internalId          String
  externalId          String
  orderNo             String?
  internalAmountCents Int             @default(0)
  externalAmountCents Int             @default(0)
  matched             Boolean         @default(false)

  report              ReconciliationReportModel @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("reconcile_match")
}

model ResolvedDiffModel {
  id          String    @id @default(uuid())
  diffKey     String    @unique
  resolvedAt  DateTime  @default(now())
  resolvedBy  String?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([diffKey])
  @@map("resolved_diff")
}

