{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/alerts/[id]",
      "regex": "^/alerts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/alerts/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/coupons/[id]",
      "regex": "^/coupons/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/coupons/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/members/[id]",
      "regex": "^/members/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/members/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/operations/[id]",
      "regex": "^/operations/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/operations/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/products/[id]",
      "regex": "^/products/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/products/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[...storeScope]",
      "regex": "^/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPstoreScope": "nxtPstoreScope"
      },
      "namedRegex": "^/(?<nxtPstoreScope>.+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/alerts",
      "regex": "^/alerts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/alerts(?:/)?$"
    },
    {
      "page": "/coupons",
      "regex": "^/coupons(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/coupons(?:/)?$"
    },
    {
      "page": "/insights",
      "regex": "^/insights(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/insights(?:/)?$"
    },
    {
      "page": "/members",
      "regex": "^/members(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/members(?:/)?$"
    },
    {
      "page": "/members/new",
      "regex": "^/members/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/members/new(?:/)?$"
    },
    {
      "page": "/operations",
      "regex": "^/operations(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/operations(?:/)?$"
    },
    {
      "page": "/products",
      "regex": "^/products(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/products(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}