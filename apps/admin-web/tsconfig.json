{
  "extends": "../../packages/config-typescript/next.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@m5/types": [
        "../../packages/types/src/index.ts"
      ],
      "@m5/ui": [
        "../../packages/ui/src/index.tsx"
      ],
      "@m5/ui/three-level-config": [
        "../../packages/ui/src/three-level-config/index.ts"
      ],
      "@m5/sdk": [
        "../../packages/sdk/src/index.ts"
      ]
    },
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "app/**/*.test.ts",
    "app/**/*.test.tsx",
    "app/stores/\\[id\\]",
    "app/stores/[id]/*",
    "app/finance/reconciliation/*"
  ]
}