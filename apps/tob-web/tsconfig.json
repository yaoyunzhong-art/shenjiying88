{
  "extends": "../../packages/config-typescript/next.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "paths": {
      "@m5/types": ["../../packages/types/src/index.ts"],
      "@m5/ui": ["../../packages/ui/src/index.tsx"],
      "@m5/sdk": ["../../packages/sdk/src/index.ts"],
      "@/*": ["./app/*"]
    },
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "app/**/*.test.ts",
    "app/**/*.test.tsx",
    ".next/types/**/* [0-9].ts",
    ".next/types/cache-life.d 2.ts",
    ".next/types/cache-life.d 3.ts",
    ".next/types/routes.d 2.ts",
    ".next/types/routes.d 3.ts",
    ".next/types/validator 2.ts",
    ".next/types/validator 3.ts"
  ]
}
