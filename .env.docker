# ═══════════════════════════════════════════════════════════════
# M5 Monorepo — Docker Compose 开发环境变量
#
# 用途:
#   docker compose --env-file .env.docker up -d
# ═══════════════════════════════════════════════════════════════

# ─── Docker 元数据 ────────────────────────────────────
COMPOSE_PROJECT_NAME=m5-dev
BUILD_TAG=latest

# ─── API ───────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:3002,http://localhost:3003,http://localhost:3011,http://localhost:5173
LYT_MODE=mock

# ─── PostgreSQL ────────────────────────────────────────
POSTGRES_USER=m5
POSTGRES_PASSWORD=m5_dev_password
POSTGRES_DB=m5_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://m5:m5_dev_password@postgres:5432/m5_dev

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-do-not-use-in-production
JWT_EXPIRES_IN=7d

# ─── LLM / AI ──────────────────────────────────────────
LLM_DEFAULT_PROVIDER=deepseek
LLM_DEEPSEEK_API_KEY=
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_DEEPSEEK_MODEL=deepseek-chat
LLM_DEEPSEEK_TIMEOUT_MS=60000
LLM_DEEPSEEK_MAX_RETRIES=3
LLM_MONTHLY_HARD_LIMIT_USD=100
LLM_EMBEDDING_PROVIDER=text-embedding-3-small

# ─── Qdrant ────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# ─── RabbitMQ ──────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=m5
RABBITMQ_PASSWORD=m5_dev_password

# ─── MinIO ─────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=m5
MINIO_SECRET_KEY=m5_dev_password

# ─── 可观测性 ──────────────────────────────────────────
ENABLE_TRACING=false
OTLP_EXPORTER=none

# ─── Prisma 入口配置 ───────────────────────────────────
PRISMA_MIGRATE=true
PRISMA_SEED=false
