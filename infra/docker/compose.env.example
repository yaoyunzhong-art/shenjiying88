BUILD_TAG=latest

# Image registry injection
API_IMAGE=shenjiying88acr20260717-registry.cn-hangzhou.cr.aliyuncs.com/shenjiying88/m5-api
ADMIN_WEB_IMAGE=shenjiying88acr20260717-registry.cn-hangzhou.cr.aliyuncs.com/shenjiying88/m5-admin-web
STOREFRONT_WEB_IMAGE=shenjiying88acr20260717-registry.cn-hangzhou.cr.aliyuncs.com/shenjiying88/m5-storefront-web
TOB_WEB_IMAGE=shenjiying88acr20260717-registry.cn-hangzhou.cr.aliyuncs.com/shenjiying88/m5-tob-web

# Database
POSTGRES_USER=m5
POSTGRES_PASSWORD=replace-with-real-password
POSTGRES_DB=m5
DATABASE_URL=postgresql://m5:replace-with-real-password@postgres:5432/m5
POSTGRES_URL=postgresql://m5:replace-with-real-password@postgres:5432/m5

# Runtime security
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d
LOG_LEVEL=info
ENABLE_TRACING=false

# Web/API routing
NEXT_PUBLIC_API_URL=https://api.m5.local/api/v1
NEXT_PUBLIC_WS_URL=wss://api.m5.local
API_INTERNAL_URL=http://api:3001
CORS_ORIGIN=http://localhost:3002,http://localhost:3003,http://localhost:3011

# Infra services
REDIS_PASSWORD=
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=m5
RABBITMQ_PASSWORD=replace-with-real-password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=m5
MINIO_ROOT_PASSWORD=replace-with-real-password
MINIO_ACCESS_KEY=m5
MINIO_SECRET_KEY=replace-with-real-password
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# LLM
LLM_DEFAULT_PROVIDER=deepseek
LLM_DEEPSEEK_API_KEY=
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
