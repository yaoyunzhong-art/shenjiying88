# ═══════════════════════════════════════════════════════════════
# M5 Platform 监控栈环境变量配置示例
# ═══════════════════════════════════════════════════════════════
# 使用方法:
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改 .env 文件中的配置值
# 3. 启动监控栈: ./scripts/start-monitoring.sh
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# Grafana 配置
# ═══════════════════════════════════════════════════════════════

# Grafana 管理员用户名
GRAFANA_ADMIN_USER=admin

# Grafana 管理员密码 (生产环境请修改为强密码)
GRAFANA_ADMIN_PASSWORD=admin

# Grafana 密钥 (用于签名, 请修改为随机字符串)
GRAFANA_SECRET_KEY=your-secret-key-change-me

# Grafana 根 URL (用于外部访问)
GRAFANA_ROOT_URL=http://localhost:3005

# ═══════════════════════════════════════════════════════════════
# Prometheus 配置
# ═══════════════════════════════════════════════════════════════

# 数据保留时间
PROMETHEUS_RETENTION_TIME=15d

# 数据保留大小 (GB)
PROMETHEUS_RETENTION_SIZE=10

# 外部 URL
PROMETHEUS_EXTERNAL_URL=http://localhost:9090

# ═══════════════════════════════════════════════════════════════
# AlertManager 配置
# ═══════════════════════════════════════════════════════════════

# 数据保留时间
ALERTMANAGER_RETENTION=120h

# 外部 URL
ALERTMANAGER_EXTERNAL_URL=http://localhost:9093

# ═══════════════════════════════════════════════════════════════
# 邮件告警配置 (SMTP)
# ═══════════════════════════════════════════════════════════════

# SMTP 服务器地址
SMTP_HOST=smtp.example.com

# SMTP 端口
SMTP_PORT=587

# SMTP 用户名
SMTP_USER=alerts@example.com

# SMTP 密码
SMTP_PASSWORD=your-smtp-password

# 发件人地址
SMTP_FROM=alerts@m5.local

# ═══════════════════════════════════════════════════════════════
# Slack 告警配置
# ═══════════════════════════════════════════════════════════════

# Slack Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# 告警频道
SLACK_CHANNEL=#alerts

# ═══════════════════════════════════════════════════════════════
# PagerDuty 告警配置
# ═══════════════════════════════════════════════════════════════

# PagerDuty Service Key
PAGERDUTY_SERVICE_KEY=your-pagerduty-service-key

# ═══════════════════════════════════════════════════════════════
# 企业微信告警配置
# ═══════════════════════════════════════════════════════════════

# 企业微信 CorpID
WECHAT_CORP_ID=your-corp-id

# 企业微信 CorpSecret
WECHAT_CORP_SECRET=your-corp-secret

# 企业微信 AgentID
WECHAT_AGENT_ID=your-agent-id

# ═══════════════════════════════════════════════════════════════
# 日志级别
# ═══════════════════════════════════════════════════════════════

# 日志级别: debug, info, warn, error
LOG_LEVEL=info
