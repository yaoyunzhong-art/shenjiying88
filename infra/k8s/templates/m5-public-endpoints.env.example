PROD_DOMAIN=sportsant.net
TLS_SECRET_NAME=m5-tls
NLB_IP_1=121.41.69.154
NLB_IP_2=120.26.66.40

ROOT_HOST=sportsant.net
WWW_HOST=www.sportsant.net
API_HOST=api.sportsant.net
ADMIN_HOST=admin.sportsant.net
STOREFRONT_HOST=store.sportsant.net
TOB_HOST=tob.sportsant.net
CDN_HOST=cdn.sportsant.net

NEXT_PUBLIC_API_URL=https://api.sportsant.net/api/v1
NEXT_PUBLIC_WS_URL=wss://api.sportsant.net
CORS_ORIGIN=https://admin.sportsant.net,https://store.sportsant.net,https://tob.sportsant.net

# cert-manager / Let's Encrypt path. This keeps the existing m5-tls contract,
# but mints the secret from exact SAN hosts instead of wildcard domains.
CERT_MANAGER_ENABLED=true
CERT_MANAGER_SOLVER_MODE=dns01
CERT_MANAGER_CLUSTER_ISSUER=letsencrypt-prod-m5
CERT_MANAGER_CERTIFICATE_NAME=m5-public-tls
CERT_MANAGER_WAIT_TIMEOUT=1200s
ACME_EMAIL=yaoyunzhong@sportantmeta.com
ACME_SERVER_URL=https://acme-v02.api.letsencrypt.org/directory
ACME_PRIVATE_KEY_SECRET_NAME=letsencrypt-prod-m5-account-key
CERT_MANAGER_WEBHOOK_GROUP_NAME=acme.sportsant.net
ALIDNS_REGION=cn-hangzhou
ALIDNS_SECRET_NAME=alidns-credentials
ALIDNS_ACCESS_KEY_ID_KEY=access-key-id
ALIDNS_ACCESS_KEY_SECRET_KEY=access-key-secret
ALIDNS_WEBHOOK_IMAGE_REPOSITORY=registry.cn-hangzhou.aliyuncs.com/wjiec/alidns-webhook
ALIDNS_WEBHOOK_IMAGE_TAG=v1.0.3

# Optional. Provide base64-encoded PEM values to render a ready-to-apply TLS secret.
# TLS_CERT_B64=
# TLS_KEY_B64=
