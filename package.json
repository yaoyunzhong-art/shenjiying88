{
  "name": "shenjiying-m5",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "commit:f11": "bash scripts/foundation11-commit.sh",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "e2e:smoke:headed": "playwright test e2e/smoke.spec.ts --headed",
    "e2e:report": "playwright show-report",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker compose -f infra/docker/docker-compose.dev.yml up -d postgres redis rabbitmq",
    "docker:up:full": "docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "docker:up:ops": "docker compose -f infra/docker/docker-compose.dev.yml -f infra/docker/docker-compose.ops.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.dev.yml down",
    "docker:down:ops": "docker compose -f infra/docker/docker-compose.dev.yml -f infra/docker/docker-compose.ops.yml down",
    "docker:logs": "docker compose -f infra/docker/docker-compose.dev.yml logs -f --tail=100",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.30.1",
    "@next/eslint-plugin-next": "^15.5.19",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.16.5",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.5.19",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1",
      "esbuild": "~0.27.7"
    },
    "packageExtensions": {
      "@react-native/babel-preset": {
        "dependencies": {
          "@babel/plugin-proposal-async-generator-functions": "^7.20.7"
        }
      }
    }
  }
}
