{
  "name": "shenjiying-m5",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:phase30:logistics": "pnpm --dir apps/api exec vitest run src/modules/logistics/logistics-ringbeam.test.ts src/modules/logistics/logistics.e2e.test.ts && pnpm --dir apps/admin-web exec node --import tsx --test app/api/logistics/material-requests/route.test.ts && pnpm --dir apps/admin-web exec node --import tsx --test app/api/logistics/clean-schedules/route.test.ts && pnpm --dir apps/admin-web exec node --import tsx --test app/api/logistics/inspections/route.test.ts && pnpm --dir apps/admin-web exec node --import tsx './app/stores/[id]/inspection/page.test.ts' && pnpm --dir apps/admin-web exec node --import tsx './app/stores/[id]/scheduling/page.test.tsx' && pnpm --dir apps/admin-web exec node --import tsx './app/stores/[id]/inventory/page.test.tsx'",
    "commit:f11": "bash scripts/foundation11-commit.sh",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "e2e:smoke:headed": "playwright test e2e/smoke.spec.ts --headed",
    "e2e:phase49:seo-geo": "bash scripts/run-phase49-seo-geo.sh",
    "e2e:l3": "playwright test --project=l3-baseline",
    "e2e:l3:headed": "playwright test --project=l3-baseline --headed",
    "e2e:report": "playwright show-report",
    "verify:api:startup-baseline": "bash scripts/verify-local-api-startup-baseline.sh",
    "preflight:api:local": "bash scripts/preflight-local-api-runtime.sh",
    "cutover:drill": "bash scripts/run-cutover-drill.sh",
    "g8:gate": "pnpm g8:preflight:prod && pnpm g8:recheck && pnpm g8:status",
    "g8:preflight:local": "pnpm preflight:api:local",
    "g8:ready": "bash scripts/run-g8-formal-window-ready.sh --env-file infra/k8s/templates/m5-public-endpoints.env.example --release-env-file infra/k8s/templates/m5-release-images.env.example --refresh-acr-regcred --window-id formal-window-$(date +%Y%m%d-%H%M%S) --log-root infra/k8s/cutover-logs",
    "g8:recheck": "bash scripts/run-g8-recheck.sh --env-file infra/k8s/templates/m5-public-endpoints.env.example --release-env-file infra/k8s/templates/m5-release-images.env.example --refresh-acr-regcred --window-id formal-window-$(date +%Y%m%d-%H%M%S) --log-root infra/k8s/cutover-logs",
    "g8:tls:precheck": "bash scripts/precheck-cert-manager-base.sh",
    "g8:tls:install-cert-manager": "bash scripts/install-cert-manager.sh",
    "g8:tls:install-alidns-webhook": "bash scripts/install-alidns-webhook.sh --env-file infra/k8s/templates/m5-public-endpoints.env.example",
    "g8:tls:create-alidns-secret": "bash scripts/create-alidns-secret.sh --env-file infra/k8s/templates/m5-public-endpoints.env.example",
    "g8:tls:provision": "bash scripts/provision-prod-cert-manager-tls.sh --env-file infra/k8s/templates/m5-public-endpoints.env.example",
    "g8:acr:refresh": "bash scripts/refresh-acr-regcred.sh",
    "g8:preflight:prod": "bash scripts/preflight-k8s-release.sh --public-env-file infra/k8s/templates/m5-public-endpoints.env.example --release-env-file infra/k8s/templates/m5-release-images.env.example --check-live-prod",
    "g8:formal": "bash scripts/run-g8-formal-window-ready.sh --env-file infra/k8s/templates/m5-public-endpoints.env.example --release-env-file infra/k8s/templates/m5-release-images.env.example --refresh-acr-regcred --window-id formal-window-$(date +%Y%m%d-%H%M%S) --log-root infra/k8s/cutover-logs --execute-apply --execute-rollback",
    "g8:status": "bash scripts/g8-window-status.sh",
    "g8:closeout": "bash scripts/g8-closeout.sh",
    "resign:bundle": "tsx scripts/generate-resign-bundle.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker compose -f infra/docker/docker-compose.dev.yml up -d postgres redis rabbitmq",
    "docker:up:full": "docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "docker:up:ops": "docker compose -f infra/docker/docker-compose.dev.yml -f infra/docker/docker-compose.ops.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.dev.yml down",
    "docker:down:ops": "docker compose -f infra/docker/docker-compose.dev.yml -f infra/docker/docker-compose.ops.yml down",
    "docker:ps": "docker compose -f infra/docker/docker-compose.dev.yml ps",
    "docker:logs": "docker compose -f infra/docker/docker-compose.dev.yml logs -f --tail=100",
    "docker:build": "docker compose build --parallel",
    "docker:build:api": "docker build --target=api-prod -t m5-api:latest .",
    "docker:build:admin": "docker build --target=admin-prod -t m5-admin:latest .",
    "docker:build:storefront": "docker build --target=storefront-prod -t m5-storefront:latest .",
    "docker:build:tob": "docker build --target=tob-prod -t m5-tob:latest .",
    "docker:prod:up": "docker compose -f docker-compose.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.yml down",
    "docker:prod:ps": "docker compose -f docker-compose.yml ps",
    "docker:prod:logs": "docker compose -f docker-compose.yml logs -f --tail=100",
    "docker:prod:restart": "docker compose -f docker-compose.yml restart",
    "docker:prod:pull": "docker compose -f docker-compose.yml pull",
    "docker:clean": "docker compose -f docker-compose.yml down -v --remove-orphans",
    "docker:prune": "docker system prune -af --volumes",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.30.1",
    "@next/eslint-plugin-next": "^15.5.19",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.20.0",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.5.19",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1",
      "esbuild": "~0.27.7"
    },
    "packageExtensions": {
      "@react-native/babel-preset": {
        "dependencies": {
          "@babel/plugin-proposal-async-generator-functions": "^7.20.7"
        }
      }
    }
  }
}
